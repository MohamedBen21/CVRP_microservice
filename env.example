# ─────────────────────────────────────────────────────────────────────────────
#  .env  —  Logistics Optimizer Configuration
# ─────────────────────────────────────────────────────────────────────────────

# OSRM base URL — swap to your self-hosted instance in production
# Public demo:   http://router.project-osrm.org
# Self-hosted:   http://localhost:5000
OSRM_URL=http://router.project-osrm.org

# Timeout (seconds) for a single OSRM table API call.
# If exceeded the system falls back to Haversine automatically.
OSRM_TIMEOUT=8

# ── Genetic Algorithm ─────────────────────────────────────────────────────────
GA_POPULATION_SIZE=60
GA_GENERATIONS=120
GA_MUTATION_RATE=0.05
GA_ELITE_SIZE=5

# ── Clustering ────────────────────────────────────────────────────────────────
# Maximum stops per cluster before we force-split.
# Keeps single-vehicle routes at a sane size.
MAX_CLUSTER_SIZE=25

# ── Service ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
